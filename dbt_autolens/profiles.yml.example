# dbt Profile Configuration Example
# Copy to ~/.dbt/profiles.yml and fill in your credentials

autolens_au:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('DB_HOST', 'localhost') }}"
      port: "{{ env_var('DB_PORT', '5432') | int }}"
      user: "{{ env_var('DB_USER', 'autolens') }}"
      password: "{{ env_var('DB_PASSWORD', '') }}"
      dbname: "{{ env_var('DB_NAME', 'autolens_au') }}"
      schema: public
      threads: 4
      connect_timeout: 10
    
    prod:
      type: postgres
      host: "{{ env_var('DB_HOST') }}"
      port: "{{ env_var('DB_PORT', '5432') | int }}"
      user: "{{ env_var('DB_USER') }}"
      password: "{{ env_var('DB_PASSWORD') }}"
      dbname: "{{ env_var('DB_NAME', 'autolens_au') }}"
      schema: public
      threads: 4
      connect_timeout: 10
