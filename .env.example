# AutoLens AU — Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database (Neon recommended for free tier)
DATABASE_URL=postgresql://user:password@host:5432/autolens_au
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autolens_au
DB_USER=autolens
DB_PASSWORD=your_secure_password

# NSW Fuel API (register at https://api.nsw.gov.au)
NSW_FUEL_API_KEY=your_api_key_here
NSW_FUEL_API_SECRET=your_api_secret_here

# Kaggle (for dataset downloads)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:8501

# Model
MODEL_PATH=models/artifacts/hedonic_model_latest.joblib
MODEL_VERSION=1.0.0
