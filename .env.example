# AutoLens AU — Environment Configuration
# Copy this file to .env and fill in your values

# Production Snowflake connection (key-pair authentication recommended)
DATABASE_BACKEND=snowflake
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_USER=your_service_user
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/secure/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_DATABASE=AUTOLENS_AU
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=AUTOLENS_WH
SNOWFLAKE_ROLE=AUTOLENS_APP
SNOWFLAKE_QUERY_TAG=autolens_local

# Hosted services can inject the PKCS#8 PEM value as SNOWFLAKE_PRIVATE_KEY
# instead of mounting SNOWFLAKE_PRIVATE_KEY_PATH. Never commit either value.

# Optional local PostgreSQL backend used by Docker Compose and secretless CI
# DATABASE_BACKEND=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/autolens_au
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=autolens_au
# DB_USER=autolens
# DB_PASSWORD=your_secure_password

# NSW Fuel API (register at https://api.nsw.gov.au)
NSW_FUEL_API_KEY=your_api_key_here
NSW_FUEL_API_SECRET=your_api_secret_here

# Kaggle (for dataset downloads)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:8501

# Model
MODEL_PATH=models/artifacts/hedonic_model_latest.joblib
MODEL_VERSION=1.0.0
MODEL_RELEASE_REPOSITORY=ozzy2438/autolens-au
