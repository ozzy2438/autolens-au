{
  "expectation_suite_name": "listings_suite",
  "ge_cloud_id": null,
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "price"},
      "meta": {"notes": "Price is required for valuation"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "price", "min_value": 1000, "max_value": 500000},
      "meta": {"notes": "Filter extreme outliers"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "brand"},
      "meta": {"notes": "Brand is a key feature"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "year"},
      "meta": {"notes": "Year is required for age calculation"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "year", "min_value": 1980, "max_value": 2027},
      "meta": {"notes": "Reasonable manufacture year range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "kilometres", "min_value": 0, "max_value": 1000000, "mostly": 0.95},
      "meta": {"notes": "Allow some nulls but values must be non-negative"}
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 10000, "max_value": 50000},
      "meta": {"notes": "Expected dataset size range"}
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.0"
  }
